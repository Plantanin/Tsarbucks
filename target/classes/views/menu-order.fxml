<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.tsarbuck.tsarbucks.controllers.MenuController"
      alignment="CENTER" spacing="20"
      stylesheets="src/main/resources/com/tsarbuck/tsarbucks/style.css"
      prefWidth="600" prefHeight="400"
      styleClass="background">

    <Button text="☕ Espresso" onAction="#orderEspresso" />
    <Button text="☕ Latte" onAction="#orderLatte" />
    <Button text="☕ Cappuccino" onAction="#orderCappuccino" />

    <Button text="❌ Abandonner" onAction="#goToLaunch" styleClass="abandonButton" />
</VBox>
