<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.text.Text?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.tsarbuck.tsarbucks.controllers.MenuController"
            stylesheets="@../css/style.css"
            styleClass="backgrounddore"
            prefWidth="405" prefHeight="798">

    <!--Header de la page avec le titre  -->
    <top>
        <VBox alignment="CENTER" spacing="10">
            <Label text="CHOIX DE LA BOISSON" styleClass="header-text"/>
        </VBox>
    </top>

    <!--main avec l'affichage de la selection dse boisson -->
    <center>
        <!--Utilisation de TilePlane pour afficher les cartes en grille -->
        <TilePane prefColumns="2" hgap="10" vgap="10" alignment="CENTER">
            <padding>
                <Insets top="10" left="10" right="10" bottom="10"/>
            </padding>

            <!--Carte du caffé Laté -->
            <VBox styleClass="card" alignment="CENTER" spacing="6" prefWidth="160" fx:id="rootCard" onMouseClicked="#handleAjouterLatte">
                <Label text="Caffé Laté" styleClass="text"/>
                <ImageView fitWidth="35" preserveRatio="true">
                    <Image url="@../images/coffee_latte.png"/>
                </ImageView>
                <!-- bouton d'ajout ou de retrait -->
                <HBox spacing="8" alignment="CENTER">
                    <Button fx:id="btnAjouterLatte" text="M" styleClass="btn-round"/>
                    <Button fx:id="btnRetirerLatte" text="L" styleClass="btn-round"/>
                </HBox>
            </VBox>

            <!--Carte expresso  -->
            <VBox styleClass="card" alignment="CENTER" spacing="6" prefWidth="160" onMouseClicked="#handleAjouterExpresso">
                <Label text="Espresso" styleClass="text"/>
                <ImageView fitWidth="35" preserveRatio="true">
                    <Image url="@../images/coffee_espresso.png"/>
                </ImageView>
                <HBox spacing="8" alignment="CENTER">
                    <Button fx:id="btnAjouterEspresso" text="M" styleClass="btn-round"/>
                    <Button fx:id="btnRetirerEspresso" text="L" styleClass="btn-round"/>
                </HBox>
            </VBox>

            <!--Carte Capuccino -->
            <VBox styleClass="card" alignment="CENTER" spacing="6" prefWidth="160" onMouseClicked="#handleAjouterCappuccino">
                <Label text="Caffé Capuccino" styleClass="text"/>
                <ImageView fitWidth="35" preserveRatio="true">
                    <Image url="@../images/coffee_cappuccino.png"/>
                </ImageView>
                <HBox spacing="8" alignment="CENTER">
                    <Button fx:id="btnAjouterCapuccino" text="M" styleClass="btn-round"/>
                    <Button fx:id="btnRetirerCapuccino" text="L" styleClass="btn-round"/>
                </HBox>
            </VBox>

        </TilePane>
    </center>

    <!--Footer avec le bouton abandon de commande et le logo -->
    <bottom>
        <VBox alignment="CENTER" spacing="8">
            <padding>
                <Insets top="8" right="10" bottom="10" left="10"/>
            </padding>
            <Button text="Abandon" styleClass="btn-red" onAction="#goToLaunch"/>
            <ImageView fitWidth="60" preserveRatio="true">
                <Image url="@../images/tsarbucks_logo.png"/>
            </ImageView>
        </VBox>
    </bottom>

</BorderPane>