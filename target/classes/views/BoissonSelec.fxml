<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.control.Slider?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.tsarbuck.tsarbucks.controllers.BoissonSelectController"

            stylesheets="@../css/style.css"
            prefWidth="405" prefHeight="798"
            styleClass="backgrounddore">

    <top>
        <VBox alignment="CENTER">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20" />
            </padding>
            <ImageView fitWidth="150" preserveRatio="true">
                <Image url="@../images/tsarbucks_logo.png" />
            </ImageView>
        </VBox>
    </top>

    <center>
        <VBox spacing="15" alignment="CENTER">
            <VBox styleClass="card" spacing="10" alignment="CENTER">
                <HBox alignment="CENTER" spacing="10">
                    <ImageView fitWidth="40" preserveRatio="true">
                        <Image url="@../images/coffee_cappuccino.png" />
                    </ImageView>
                    <Label fx:id="labelNomBoisson" />
                </HBox>

                <HBox spacing="20" alignment="CENTER">
                    <Button fx:id="btnTailleM" text="M" styleClass="btn-round" onAction="#setCommandeTailleM"/>
                    <Button fx:id="btnTailleL" text="L" styleClass="btn-round" onAction="#setCommandeTailleL"/>
                </HBox>

                <Label fx:id="labelSucreBoisson" text="Sucre Ajouté :" styleClass="label" />
                <Slider fx:id="sliderSucre" styleClass="slider-style" prefWidth="200"
                        min="0" max="1" value="0.4" blockIncrement="0.1" />

                <Label fx:id="labelLaitBoisson" text="Lait Ajouté :" styleClass="label" />
                <Slider fx:id="sliderLait" styleClass="slider-style" prefWidth="200"
                        min="0" max="1" value="0.6" blockIncrement="0.1" />
            </VBox>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" spacing="30">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20" />
            </padding>
            <Button fx:id="btnRetour" text="Retour" styleClass="btn-red" onAction="#goToPreviousScene" />
            <Button fx:id="btnConfirmer" text="Confirmer" styleClass="btn-red" onAction="#goToNextScene" />
        </HBox>
    </bottom>

</BorderPane>