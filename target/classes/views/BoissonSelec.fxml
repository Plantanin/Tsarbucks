<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.control.Slider?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.tsarbuck.tsarbucks.controllers.BoissonSelectController"

            stylesheets="@../css/style.css"
            prefWidth="405" prefHeight="798"
            styleClass="backgrounddore">

    <!--Section pour afficher le logo  -->
    <top>
        <VBox alignment="CENTER">
            <!--Mise en place de padding pour placer le logo -->
            <padding>
                <Insets top="20" right="20" bottom="20" left="20" />
            </padding>
            <ImageView fitWidth="150" preserveRatio="true">
                <Image url="@../images/tsarbucks_logo.png" />
            </ImageView>
        </VBox>
    </top>

    <center>
        <VBox spacing="15" alignment="CENTER">
            <VBox styleClass="card" spacing="10" alignment="CENTER">
                <HBox alignment="CENTER" spacing="10">
                    <ImageView fitWidth="40" preserveRatio="true">
                        <Image url="@../images/coffee_cappuccino.png" />
                    </ImageView>
                    <Text styleClass="text">Caffé Capuccino</Text>
                </HBox>

                <HBox spacing="20" alignment="CENTER">
                    <Button fx:id="btnAjouter" text="Ajouter" styleClass="btn-round" />
                    <Button fx:id="btnRetirer" text="Retirer" styleClass="btn-round" />
                </HBox>
                <!-- Slider gradué pour le sucre -->
                <Label fx:id="labelSucre" text="Sucre Ajouté :" styleClass="label" />
                <Slider fx:id="sliderSucre"
                        styleClass="slider-style"
                        min="0" max="3" value="1"
                        blockIncrement="1"
                        majorTickUnit="1"
                        minorTickCount="0"
                        snapToTicks="true"
                        showTickMarks="true"
                        showTickLabels="true" />

                <!-- Slider gradué pour le lait -->
                <Label fx:id="labelLait" text="Lait Ajouté :" styleClass="label" />
                <Slider fx:id="sliderLait"
                        styleClass="slider-style"
                        min="0" max="3" value="1"
                        blockIncrement="1"
                        majorTickUnit="1"
                        minorTickCount="0"
                        snapToTicks="true"
                        showTickMarks="true"
                        showTickLabels="true" />
            </VBox>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" spacing="30">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20" />
            </padding>
            <Button fx:id="btnRetour" text="Retour" styleClass="btn-red" />
            <Button fx:id="btnConfirmer" text="Confirmer" styleClass="btn-red" />
        </HBox>
    </bottom>

</BorderPane>